{
  // Zed config mirroring the Sublime Text 4 setup (Catppuccin Mocha +
  // MesloLGS Nerd Font Mono @ 17, matches Alacritty).
  //
  // NOTE: the Ollama `api_url` below is a PLACEHOLDER (OLLAMA_HOST). On a real
  // machine, replace it with your Ollama server's host:port (this repo is
  // public, so the real LAN IP is kept out of git). See zed/README.md.

  "cli_default_open_behavior": "existing_window",
  "session": {
    "trust_all_worktrees": true
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "julia": true,
    "toml": true
  },
  "theme": {
    "mode": "dark",
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte"
  },
  "icon_theme": "Catppuccin Mocha",

  // ── Font ────────────────────────────────────────────────────────────
  // calt enables ligatures (Meslo has a few; harmless if absent).
  "buffer_font_family": "MesloLGS Nerd Font Mono",
  "buffer_font_size": 17,
  "buffer_font_features": { "calt": true },
  "buffer_line_height": "comfortable",
  "ui_font_family": "MesloLGS Nerd Font Mono",
  "ui_font_size": 15,
  "terminal": {
    "font_family": "MesloLGS Nerd Font Mono",
    "font_size": 15,
    "copy_on_select": true
  },

  // ── Editor feel & UI ────────────────────────────────────────────────
  "tab_size": 2,
  "soft_wrap": "none",
  "relative_line_numbers": "disabled",
  "current_line_highlight": "all",
  "cursor_blink": true,
  "show_whitespaces": "selection",
  "show_wrap_guides": true,
  "wrap_guides": [80, 100],
  "scroll_beyond_last_line": "one_page",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "minimap": {
    "show": "auto",
    "thumb": "hover"
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "search_results": true
  },
  "gutter": {
    "line_numbers": true,
    "code_actions": true,
    "runnables": true,
    "folds": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_close_button": "hover"
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },
  "project_panel": {
    "dock": "left",
    "git_status": true,
    "auto_reveal_entries": true,
    "indent_size": 16
  },
  "file_finder": {
    "modal_max_width": "medium"
  },
  "inlay_hints": {
    "enabled": true,
    "show_parameter_hints": true,
    "show_type_hints": true
  },

  // Git: inline blame (like GitLens) + gutter diff indicators.
  "git": {
    "inline_blame": { "enabled": true, "delay_ms": 600 },
    "git_gutter": "tracked_files"
  },

  // Vim mode ON so nvim muscle memory carries over.
  "vim_mode": true,

  // ── Format / save ───────────────────────────────────────────────────
  "format_on_save": "on",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,

  // ── Per-language overrides ──────────────────────────────────────────
  "languages": {
    "Markdown": {
      // Prose: wrap to the editor, and DON'T strip trailing whitespace —
      // markdown uses two trailing spaces for hard line breaks.
      "soft_wrap": "editor_width",
      "remove_trailing_whitespace_on_save": false,
      "format_on_save": "off",
      "show_wrap_guides": false
    },
    "Julia": {
      "tab_size": 4
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "JSON": { "tab_size": 2 },
    "JSONC": { "tab_size": 2 },
    "TOML": { "tab_size": 2 }
  },

  // ── AI assistant → local Ollama (free local inference) ───────────────
  // Replace OLLAMA_HOST with your Ollama server host:port (e.g. 10.0.0.5:11434).
  "language_models": {
    "ollama": {
      "api_url": "http://OLLAMA_HOST:11434",
      "available_models": [
        {
          "name": "qwen3:14b",
          "display_name": "Qwen3 14B (local)",
          "max_tokens": 32768,
          "supports_tools": true,
          "supports_thinking": true
        },
        {
          "name": "deepseek-r1:14b",
          "display_name": "DeepSeek-R1 14B (local)",
          "max_tokens": 32768,
          "supports_thinking": true
        },
        {
          "name": "gemma4:e4b",
          "display_name": "Gemma 4 e4b (local)",
          "max_tokens": 8192
        }
      ]
    }
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "ollama",
      "model": "qwen3:14b"
    },
    "inline_assistant_model": {
      "provider": "ollama",
      "model": "qwen3:14b"
    }
  },

  // Don't phone home.
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}

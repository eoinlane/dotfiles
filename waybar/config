{
  "layer": "top",
  "position": "top",
  "height": 28,
  "spacing": 4,
  "modules-left":  ["sway/workspaces", "sway/mode"],
  "modules-center":["sway/window"],
  "modules-right": ["idle_inhibitor", "pulseaudio", "custom/network", "cpu", "memory", "disk", "clock", "tray"],

  "sway/workspaces": { "disable-scroll": true, "all-outputs": true, "format": "{name}" },
  "sway/window":     { "max-length": 60 },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": { "activated": "\uf06e", "deactivated": "\uf070" },
    "tooltip-format-activated": "Idle inhibitor: on (click to disable)",
    "tooltip-format-deactivated": "Idle inhibitor: off (click to enable)"
  },

  "pulseaudio": {
    "format": "\uf028 {volume}%",
    "format-muted": "\uf6a9 muted",
    "format-bluetooth": "\uf293 {volume}%",
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "exec pavucontrol",
    "tooltip-format": "{desc}"
  },

  "custom/network": {
    "exec": "~/.config/waybar/network-status.sh",
    "return-type": "json",
    "interval": 5
  },

  "cpu":     { "format": "\uf2db {usage}%", "interval": 2 },
  "memory":  { "format": "\uefc5 {percentage}%", "interval": 5 },
  "disk":    { "format": "\uf0a0 {percentage_used}%", "path": "/", "interval": 30 },
  "clock":   {
    "format": "\uf017 {:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "tray":    { "icon-size": 16, "spacing": 8 }
}

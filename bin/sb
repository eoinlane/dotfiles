#!/usr/bin/env bash
# sb — open the second brain in one command: a single nvim window in the
# secondbrain dir. No Claude pane.
set -euo pipefail

dir="${SECONDBRAIN:-$HOME/Documents/secondbrain}"
[[ -d "$dir" ]] || { echo "sb: no such dir: $dir (set \$SECONDBRAIN to override)" >&2; exit 1; }
cd "$dir"

exec nvim

#!/usr/bin/env bash
# sbb — nvim in the secondbrain dir, opened on today's :KBBrief. No Claude pane;
# a single full-width nvim window. The brief query runs over the SSH seam to the
# M3, so it fills in a moment after nvim starts.
set -euo pipefail

dir="${SECONDBRAIN:-$HOME/Documents/secondbrain}"
[[ -d "$dir" ]] || { echo "sbb: no such dir: $dir (set \$SECONDBRAIN to override)" >&2; exit 1; }
cd "$dir"

# kb.nvim loads on VeryLazy, so force it in first — else :KBBrief isn't defined
# yet at -c time (E492).
exec nvim -c 'lua require("lazy").load({plugins={"kb.nvim"}})' -c 'KBBrief'

{
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(dmesg *)",
      "Bash(swaymsg reload)",
      "Bash(swaymsg -t *)",
      "Bash(swaymsg get_*)",

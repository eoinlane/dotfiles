      "Bash(zpool list *)",
      "Bash(zfs list *)",
      "Bash(zfs get *)",
      "Bash(swapinfo *)",
      "Bash(procstat *)",
      "Bash(sockstat *)",
      "Bash(usbconfig list *)",
      "Bash(freebsd-version *)",
      "Bash(jls *)",
      "Bash(fc-match *)",
      "Bash(fc-list *)",
      "Bash(fc-cache *)",
      "Bash(pgrep *)",
      "Bash(cliphist list *)",
      "Bash(wl-copy)",
      "Bash(wl-paste *)",
      "Bash(kldstat *)",
      "Bash(sysctl -n *)",
      "Bash(swaynag *)"

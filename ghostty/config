# Ghostty config — ported from ~/dotfiles/alacritty/alacritty.toml

# Font. Ghostty derives the bold/italic faces from the family automatically,
# so the three separate entries Alacritty needed collapse to one line.
font-family = JetBrainsMono Nerd Font
font-size = 20

# Shell — match Alacritty's explicit fish launch.
command = /opt/homebrew/bin/fish

# --- Optional Ghostty extras (uncomment to try) ---
# Ghostty has native tabs + splits, so you may not need tmux for simple layouts.
# Run `ghostty +list-keybinds` to see the defaults, `ghostty +list-themes` for themes.

# Theme — Catppuccin Mocha, to match Alacritty, tmux, Zed and Sublime across the
# estate. Ghostty bundles it (named with a space + capitals — `ghostty
# +list-themes` to browse). Use "Catppuccin Latte" for a light variant, or
# "iTerm2 Solarized Dark" to go back to the old port.
theme = Catppuccin Mocha

# background-opacity = 0.96
# macos-option-as-alt = true

# ============================================================
# Second-brain / nvim workflow  (added 2026-07-06)
# ============================================================

# --- Splits: nvim + Claude side by side ---------------------
# cmd+d / cmd+shift+d match Ghostty's macOS defaults; kept explicit so the
# layout is self-documenting. `sb` (in ~/.local/bin) launches nvim with a
# Claude pane already split beside it.
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+left=goto_split:left
keybind = cmd+opt+right=goto_split:right
keybind = cmd+opt+up=goto_split:up
keybind = cmd+opt+down=goto_split:down
keybind = cmd+shift+enter=toggle_split_zoom

# --- Quick terminal: dropdown for a fast KB query -----------
# cmd+` toggles a dropdown terminal while Ghostty is focused. To summon it from
# *any* app (system-wide), change this to `global:cmd+grave_accent=...` AND grant
# Ghostty Accessibility permission (System Settings > Privacy & Security).
quick-terminal-position = top
quick-terminal-animation-duration = 0.12
keybind = cmd+grave_accent=toggle_quick_terminal

# --- Shell integration --------------------------------------
# cwd inheritance for new splits/tabs, sudo passthrough, and prompt marks.
# Marks power jump-to-prompt, which Ghostty already binds to cmd+up / cmd+down.
shell-integration = fish
shell-integration-features = cursor,sudo,title
window-inherit-working-directory = true

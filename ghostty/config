# Ghostty config — ported from ~/dotfiles/alacritty/alacritty.toml

# Font. Ghostty derives the bold/italic faces from the family automatically,
# so the three separate entries Alacritty needed collapse to one line.
font-family = JetBrainsMono Nerd Font
font-size = 14

# Shell — match Alacritty's explicit fish launch.
command = /opt/homebrew/bin/fish

# --- Optional Ghostty extras (uncomment to try) ---
# Ghostty has native tabs + splits, so you may not need tmux for simple layouts.
# Run `ghostty +list-keybinds` to see the defaults, `ghostty +list-themes` for themes.

# Theme — Catppuccin Mocha, to match Alacritty, tmux, Zed and Sublime across the
# estate. Ghostty bundles it (named with a space + capitals — `ghostty
# +list-themes` to browse). Use "Catppuccin Latte" for a light variant, or
# "iTerm2 Solarized Dark" to go back to the old port.
theme = Catppuccin Mocha

# background-opacity = 0.96
# macos-option-as-alt = true
